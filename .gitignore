# ── Auth sessions / secrets — NEVER commit ──────────────────
# These are machine-specific session files generated at runtime.
# They are stored in ~/.wibey/ (outside the repo), not here.
# The .auth-complete sentinel is also in ~/.wibey/sarthi/.
scripts/crq/chrome_profile/
scripts/crq/*.bak*
scripts/crq/__pycache__/

# ── snow-ad-automation runtime state ────────────────────────
scripts/snow-ad-automation/.venv/
scripts/snow-ad-automation/chrome_profile/
scripts/snow-ad-automation/config.yaml
scripts/snow-ad-automation/.servicenow_cookies.pkl
scripts/snow-ad-automation/__pycache__/
scripts/snow-ad-automation/bkp/
scripts/snow-ad-automation/html_page*.txt

# ── Python cache ─────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
*.pyc

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V*
.Trashes

# ── Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Node (only if node_modules ever appears in repo) ─────────
node_modules/
